# ─────────────────────────────────────────────
# KeluargaKas Frontend — Environment Variables
# Salin file ini menjadi .env dan sesuaikan nilainya
# ─────────────────────────────────────────────

# Base URL backend Laravel (tanpa trailing slash)
# Dev  → http://localhost:8000
# Prod → https://api.keluargakas.app
VITE_API_BASE_URL=http://localhost:8000

# Nama aplikasi
VITE_APP_NAME=KeluargaKas
