# ─────────────────────────────────────────────
# KeluargaKas Frontend — .gitignore
# ─────────────────────────────────────────────

# ── Dependencies ──────────────────────────────
node_modules/
.pnp
.pnp.js

# ── Build Output ─────────────────────────────
dist/
dist-ssr/

# ── Environment (RAHASIA — jangan pernah di-commit) ─
.env
.env.local
.env.*.local

# .env.example BOLEH di-commit (tidak mengandung secret)

# ── Vite Cache ───────────────────────────────
.vite/
*.local

# ── Editor & IDE ─────────────────────────────
.vscode/*
!.vscode/extensions.json
.idea/
*.suo
*.ntvs*
*.njsproj
*.sln
*.sw?

# ── OS Files ─────────────────────────────────
.DS_Store
Thumbs.db
desktop.ini

# ── Logs ─────────────────────────────────────
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
*.log

# ── Lock files (pilih salah satu sesuai package manager) ─
# Jika pakai npm → commit package-lock.json, ignore yang lain
yarn.lock
pnpm-lock.yaml

# ── Test & Coverage ───────────────────────────
coverage/
*.lcov
